{
    "name": "vite-alpine-tailwind",
    "version": "1.3.0",
    "description": "A lightweight client-side SPA starter combining Vite, Alpine.js and Tailwind CSS — UI authored as native Web Components, routed with pinecone-router",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check --write .",
        "release": "release-it"
    },
    "release-it": {
        "git": {
            "push": true
        },
        "github": {
            "release": true,
            "releaseName": "Release ${version}"
        },
        "npm": {
            "publish": false
        }
    },
    "keywords": [
        "vite",
        "alpinejs",
        "tailwindcss",
        "web-components",
        "custom-elements",
        "pinecone-router",
        "spa",
        "template",
        "starter",
        "typescript"
    ],
    "author": "vzsoares",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/vzsoares/vite-alpine-tailwind.git"
    },
    "homepage": "https://github.com/vzsoares/vite-alpine-tailwind",
    "bugs": {
        "url": "https://github.com/vzsoares/vite-alpine-tailwind/issues"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.3.0",
        "@types/alpinejs": "^3.13.11",
        "alpinejs": "^3.15.12",
        "daisyui": "^5.5.20",
        "pinecone-router": "^7.5.1",
        "release-it": "^20.0.1",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    },
    "dependencies": {}
}
